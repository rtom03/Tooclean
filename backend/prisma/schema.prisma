// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoReview {
  id        String   @id @default(uuid())
  name      String
  file      String   // could be a URL or file path
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  color      String
  description String
  qty         Int
  images      String[] // array of image URLs
  items     OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment_Info {
  id                   String   @id @default(uuid())  
  orderNumber          String   @unique
  customerName         String
  email                String
  phone                String
  address              String
  state                String
  deliveryPrice        Float?
  orderDetails         Json
  total                Float
  status               String   @default("pending")  // pending | paid | processing | shipped | delivered | failed
  paymentStatus        String   @default("unpaid")   // unpaid | paid
  paystackCustomerCode String?
  dedicatedAccountNo   String?
  dedicatedBankName    String?
  dedicatedAccountName String?
  paystackReference    String?
  deliveryStatus       String @default("not_created")
  fezTrackingId        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

